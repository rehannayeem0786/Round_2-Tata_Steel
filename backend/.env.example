# ─── Intelligent Maintenance Wizard — Environment Configuration ───

# ─── LLM Provider API Keys (set at least ONE) ───
# Provider priority: NVIDIA > Groq > OpenRouter > Google. If none is set,
# the system runs in fallback mode (RAG + analytics still fully functional).

# NVIDIA NIM (recommended — fast 70B reasoning). Get one at: https://build.nvidia.com
NVIDIA_API_KEY=

# Groq Cloud (very fast). Get one at: https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter (free models available). Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# LLM Settings (free model from OpenRouter)
LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
LLM_TEMPERATURE=0.3

# Google Gemini API Key (alternative, optional)
# GOOGLE_API_KEY=

# Server Settings
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Sensor Simulator
SENSOR_INTERVAL=5
ANOMALY_PROBABILITY=0.05

# RAG Settings
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.3
